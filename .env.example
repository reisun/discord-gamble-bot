# ============================================================
# Discord Gamble Bot - 環境変数テンプレート
# このファイルをコピーして .env を作成してください
# cp .env.example .env
# ============================================================

# --- PostgreSQL ---
POSTGRES_DB=gamble_bot
POSTGRES_USER=gamble_user
POSTGRES_PASSWORD=changeme_strong_password

# --- Webサーバー (Express.js) ---
# docker-compose 内から db コンテナに接続する場合
DATABASE_URL=postgresql://gamble_user:changeme_strong_password@db:5432/gamble_bot
SERVER_PORT=3000
# --- Discord Bot ---
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_ADMIN_ROLE_ID=your_admin_role_id_here
# Bot から API サーバーへの接続先（docker-compose 内では service 名を使用）
API_BASE_URL=http://server:3000
# /admin-link, /link コマンドで返す WebアプリのURLの既定部分
WEB_APP_BASE_URL=https://reisun.github.io/discord-gamble-bot/

# --- Webアプリ (React / Vite) ---
# ブラウザから API を呼び出す際のベース URL（nginx 経由の場合は /api）
VITE_API_BASE_URL=/api

# --- WebAPIサーバー (Express.js) ---
# CORS を許可するオリジン（カンマ区切りで複数指定可）
# GitHub Pages と自ドメインの両方を許可する
# nginx の server_name に使用するドメイン名
SERVER_NAME=your-domain.example.com
CORS_ALLOWED_ORIGINS=https://reisun.github.io,https://your-domain.example.com

# --- 共通 ---
NODE_ENV=development
